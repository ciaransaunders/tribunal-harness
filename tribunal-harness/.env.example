# Tribunal Harness — Environment Variables
# Copy this file to .env.local and fill in your values.

# REQUIRED — Powers /api/analyse and /api/triage (Anthropic Claude Sonnet 4)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OPTIONAL — Email notifications when someone submits the access request form
# Sign up at https://resend.com
RESEND_API_KEY=re_...
NOTIFY_EMAIL=hello@tribunalharness.co.uk

# REQUIRED ONLY if using /api/webhook endpoint
# Set this for local testing of webhooks to ensure HMAC validation passes.
WEBHOOK_SECRET=your-hmac-secret-here

# OPTIONAL — Override ERA 2025 time limit commencement date when SI is confirmed
# Default: 2026-10-01 (from constants.ts)
# ERA_2025_TIME_LIMIT_COMMENCEMENT=2026-10-01

# Key Value Store
KV_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""

# Neon Database
DATABASE_URL=""
